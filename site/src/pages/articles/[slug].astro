---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getArticleBySlug, getArticles } from "@/lib/content";

export function getStaticPaths() {
  return getArticles().map((article) => ({
    params: { slug: article.frontmatter.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const discussionUrl =
  typeof article.frontmatter.discussion?.url === "string" && article.frontmatter.discussion.url
    ? article.frontmatter.discussion.url
    : undefined;
const discussionIssue =
  typeof article.frontmatter.discussion?.issue === "number" ? article.frontmatter.discussion.issue : undefined;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const tocSections = article.toc.reduce<Array<(typeof article.toc)[number] & { children: typeof article.toc }>>(
  (sections, item) => {
    if (item.depth === 2) {
      sections.push({ ...item, children: [] });
    } else if (sections.length > 0) {
      sections[sections.length - 1].children.push(item);
    }

    return sections;
  },
  [],
);
const speedReadBySlug: Record<string, string[]> = {
  "from-llm-wiki-to-personal-harness": [
    "Karpathy 的 LLM Wiki 提供的是可读 Markdown、index 与 wikilinks 组成的极简骨架。",
    "我的扩展是三层：采集层接入信号，编译层沉淀 wiki，蒸馏层承接日记与读书触动。",
    "关键边界是 raw 放事实素材，wiki 放编译结果，insights 保留人类判断。",
    "读书工作流不追求导出更多，而是用 RIA 把触动点转成理解和行动。",
    "个人 Harness 的价值不在工具链本身，而在让问答、阅读和碎片输入持续回流成知识资产。",
  ],
  "kain-trading-agent-architecture": [
    "这篇文章的核心不是让 AI 更会下单，而是把真实资金相关 Agent 的权限拆到足够窄。",
    "Kain 的生产架构分成研究、监督、风控、执行和保护五层：RD-Agent/Qlib 只做 shadow 证据，CCXT 才是唯一执行边界。",
    "Hermes 被从“交易员”降级为 supervisor：它可以解释候选、复盘和生成结构化 intent，但不能绕过 Router / Risk Governor。",
    "Router / Risk Governor 的价值在于能拒绝开仓：账户权益、trader、tier、regime、止损、杠杆和风险预算都必须先过硬规则。",
    "最适合先生产化的部分可能不是自动开仓，而是 7x24 的只降风险保护链路：补 SL、清理异常保护单、维护 TP 和 trailing。",
  ],
  "agent-native-video-filesystem": [
    "这篇文章的核心判断是：AI 视频真正的变化不是一次生成成片，而是把视频拆成 Agent 能读写、能检查、能重跑的一套文件。",
    "当脚本、分镜、旁白、字幕、画面代码和发布元数据都显式存在时，Agent 才能局部修改、定位问题并维护视频项目。",
    "HyperFrames 的价值在于把视频流程拆成 capture、design、script、storyboard、voiceover、build、validate 等可追踪节点。",
    "Remotion、HyperFrames、GSAP Skills 和 PPT Skill 指向同一层变化：创作能力正在从软件 UI 变成可组合的目录结构、规则和检查命令。",
    "最先落地的不是全自动电影，而是产品 demo、技术文章转视频、数据报告视频和教学讲解视频这类结构强、素材可控的创作 Harness。",
  ],
  "real-cost-of-ai-coding": [
    "这篇文章的核心判断是：AI 编程真正便宜的是让代码出现，真正昂贵的是让代码安全、可审查地留下来。",
    "GitHub Copilot 用量计费让模型、输入输出 token 和缓存 token 的成本显性化，包月时代隐藏的粗糙用法会直接进入账单。",
    "最麻烦的不是完全错误的代码，而是“差不多对”的代码：它能编译、像真代码，却把风险转移到 review、测试和长期维护里。",
    "成熟团队需要给 Coding Agent 补上规格、测试、权限、回滚、审计和人工审批，这些流程税才是真实生产成本。",
    "团队不该只看 token 面板，而应建立工程成本仪表盘：PR 返工率、review 时间、测试失败率、回滚率、审批次数和模型分流比例都要纳入。",
  ],
};
const speedReadPoints = speedReadBySlug[article.frontmatter.slug] ?? [article.frontmatter.summary];
---

<BaseLayout title={`${article.frontmatter.title} · Mind-OS Public`} description={article.frontmatter.summary}>
  <article class="article-page">
    <div class="article-reading-layout">
      <header class="article-hero">
        <a class="back-link" href={base}>← 返回文章列表</a>
        <p class="eyebrow">Article · {article.frontmatter.date} · {article.readingMinutes} 分钟</p>
        <h1>{article.frontmatter.title}</h1>
        <p class="article-summary">{article.frontmatter.summary}</p>
        <div class="article-meta">
          <div class="tags">
            {article.frontmatter.tags.map((tag, index) => <span class={`tag tone-${(index % 5) + 1}`}>{tag}</span>)}
          </div>
          {discussionUrl && <a class="button primary compact" href={discussionUrl}>参与讨论 #{discussionIssue}</a>}
        </div>
      </header>

      <aside class="article-toc" aria-label="章节目录">
        <details class="article-toc-inner" open>
          <summary class="toc-panel-summary">
            <span class="toc-kicker">章节目录</span>
          </summary>
          <ol class="toc-list">
            {
              tocSections.map((section) => (
                <li>
                  <a class="toc-link toc-link-section" href={`#${section.id}`}>
                    {section.text}
                  </a>
                  {section.children.length > 0 && (
                    <ol class="toc-children">
                      {section.children.map((child) => (
                        <li>
                          <a class="toc-link toc-link-child" href={`#${child.id}`}>
                            {child.text}
                          </a>
                        </li>
                      ))}
                    </ol>
                  )}
                </li>
              ))
            }
          </ol>
        </details>
      </aside>

      <section class="article-speed-read" aria-labelledby="speed-read-title">
        <div class="speed-read-heading">
          <p class="toc-kicker">AI 速读</p>
          <h2 id="speed-read-title">5 分钟速读</h2>
        </div>
        <ol class="speed-read-list">
          {speedReadPoints.map((point) => <li>{point}</li>)}
        </ol>
      </section>

      <div class="article-content" set:html={article.html} />
    </div>
  </article>
</BaseLayout>
