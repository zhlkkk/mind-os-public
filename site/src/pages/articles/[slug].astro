---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { assetHref, getArticleBySlug, getArticles } from "@/lib/content";

export function getStaticPaths() {
  return getArticles().map((article) => ({
    params: { slug: article.frontmatter.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const discussionUrl =
  typeof article.frontmatter.discussion?.url === "string" && article.frontmatter.discussion.url
    ? article.frontmatter.discussion.url
    : undefined;
const discussionIssue =
  typeof article.frontmatter.discussion?.issue === "number" ? article.frontmatter.discussion.issue : undefined;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const tocSections = article.toc.reduce<Array<(typeof article.toc)[number] & { children: typeof article.toc }>>(
  (sections, item) => {
    if (item.depth === 2) {
      sections.push({ ...item, children: [] });
    } else if (sections.length > 0) {
      sections[sections.length - 1].children.push(item);
    }

    return sections;
  },
  [],
);
const speedReadBySlug: Record<string, string[]> = {
  "from-llm-wiki-to-personal-harness": [
    "Karpathy 的 LLM Wiki 提供的是可读 Markdown、index 与 wikilinks 组成的极简骨架。",
    "我的扩展是三层：采集层接入信号，编译层沉淀 wiki，蒸馏层承接日记与读书触动。",
    "关键边界是 raw 放事实素材，wiki 放编译结果，insights 保留人类判断。",
    "读书工作流不追求导出更多，而是用 RIA 把触动点转成理解和行动。",
    "个人 Harness 的价值不在工具链本身，而在让问答、阅读和碎片输入持续回流成知识资产。",
  ],
  "kain-trading-agent-architecture": [
    "这篇文章的核心不是让 AI 更会下单，而是把真实资金相关 Agent 的权限拆到足够窄。",
    "Kain 的生产架构分成研究、监督、风控、执行和保护五层：RD-Agent/Qlib 只做 shadow 证据，CCXT 才是唯一执行边界。",
    "Hermes 被从“交易员”降级为 supervisor：它可以解释候选、复盘和生成结构化 intent，但不能绕过 Router / Risk Governor。",
    "Router / Risk Governor 的价值在于能拒绝开仓：账户权益、trader、tier、regime、止损、杠杆和风险预算都必须先过硬规则。",
    "最适合先生产化的部分可能不是自动开仓，而是 7x24 的只降风险保护链路：补 SL、清理异常保护单、维护 TP 和 trailing。",
  ],
  "agent-native-video-filesystem": [
    "这篇文章的核心判断是：AI 视频真正的变化不是一次生成成片，而是把视频拆成 Agent 能读写、能检查、能重跑的一套文件。",
    "当脚本、分镜、旁白、字幕、画面代码和发布元数据都显式存在时，Agent 才能局部修改、定位问题并维护视频项目。",
    "HyperFrames 的价值在于把视频流程拆成 capture、design、script、storyboard、voiceover、build、validate 等可追踪节点。",
    "Remotion、HyperFrames、GSAP Skills 和 PPT Skill 指向同一层变化：创作能力正在从软件 UI 变成可组合的目录结构、规则和检查命令。",
    "最先落地的不是全自动电影，而是产品 demo、技术文章转视频、数据报告视频和教学讲解视频这类结构强、素材可控的创作 Harness。",
  ],
  "real-cost-of-ai-coding": [
    "这篇文章的核心判断是：AI 编程真正便宜的是让代码出现，真正昂贵的是让代码安全、可审查地留下来。",
    "GitHub Copilot 用量计费让模型、输入输出 token 和缓存 token 的成本显性化，包月时代隐藏的粗糙用法会直接进入账单。",
    "最麻烦的不是完全错误的代码，而是“差不多对”的代码：它能编译、像真代码，却把风险转移到 review、测试和长期维护里。",
    "成熟团队需要给 Coding Agent 补上规格、测试、权限、回滚、审计和人工审批，这些流程税才是真实生产成本。",
    "团队不该只看 token 面板，而应建立工程成本仪表盘：PR 返工率、review 时间、测试失败率、回滚率、审批次数和模型分流比例都要纳入。",
  ],
  "gitbutler-agent-safe-git": [
    "GitButler 不是 GitHub 替代品，而是在现有 Git 仓库上加的工作区组织层：同目录多泳道、按 file/hunk 分拣 diff。",
    "Agent 写代码越来越快，真正慢的是混杂 diff 的整理；GitButler 用 virtual branches 和 but stage 把后置分拣做成可审查历史。",
    "release/0.20.0 起 Agent 主线是 but skill install，不是旧文档里的 MCP 或桌面内嵌 Claude Code GUI。",
    "和 git worktree 分工不同：worktree 隔离运行时，泳道隔离提交历史；强隔离用 worktree，同目录整理用泳道。",
    "试点前记住硬边界：不要碰 gitbutler/workspace，Agent 只本地 commit 不自动 push，大改历史前先 but oplog snapshot。",
  ],
  "claude-code-expertise": [
    "Anthropic 对 398,198 个 Claude Code 会话的分析说明：AI 越能执行，越奖励懂业务、懂系统边界的人。",
    "Claude Code 已经不只是修 bug 工具，真实使用正在扩展到写代码、测试、部署、配置、理解系统、规划变更、数据分析和文档沟通。",
    "典型分工是人负责约 70% 的规划决策，AI 负责约 80% 的执行决策；高质量委托要给目标、禁区和验收标准。",
    "专家用户不是写更多步骤，而是给更清楚的约束；他们单条提示能触发更多动作和更长输出，因为执行空间被定义得更可靠。",
    "AI 降低的是实现门槛，抬高的是验收门槛；程序员壁垒正在转向系统判断、工程边界、风险意识和业务语义理解。",
  ],
  "controlled-language-prompt-engineering": [
    "受控语言不是新造概念，而是一组限制词汇、语法和语义的写作方法，用来减少歧义、提升可读性，并让机器更稳定地处理文本。",
    "Basic English、Plain English 和 Simplified Technical English 的共同点，是用规则换取理解稳定性。",
    "软件团队不必照搬航空版 STE，更适合组合使用 Plain English、开发者文档风格指南、Docs as Code 和少量 STE 规则。",
    "Prompt Engineering 的很多问题不是模型玄学，而是语言边界不清：模糊词、长句、多重意图和缺少验收标准都会扩大解释空间。",
    "团队要把清楚变成规则：触发条件、操作词、流程、输出格式、停止条件和验证方法都应该写进文档、模板或 Skill。",
  ],
};
const speedReadPoints = speedReadBySlug[article.frontmatter.slug] ?? [article.frontmatter.summary];
const coverSrc = assetHref(article.frontmatter.cover);
const carouselSlides = article.carouselSlides
  .map((slide) => ({
    ...slide,
    src: assetHref(slide.path),
  }))
  .filter((slide) => slide.src);
---

<BaseLayout title={`${article.frontmatter.title} · Mind-OS Public`} description={article.frontmatter.summary}>
  <article class="article-page">
    <div class="article-reading-layout">
      <header class="article-hero">
        <a class="back-link" href={base}>← 返回文章列表</a>
        <p class="eyebrow">Article · {article.frontmatter.date} · {article.readingMinutes} 分钟</p>
        <h1>{article.frontmatter.title}</h1>
        <p class="article-summary">{article.frontmatter.summary}</p>
        <div class="article-meta">
          <div class="tags">
            {article.frontmatter.tags.map((tag, index) => <span class={`tag tone-${(index % 5) + 1}`}>{tag}</span>)}
          </div>
          {discussionUrl && <a class="button primary compact" href={discussionUrl}>参与讨论 #{discussionIssue}</a>}
        </div>
      </header>

      {coverSrc && (
        <figure class="article-cover-hero">
          <img src={coverSrc} alt={`${article.frontmatter.title} 封面`} loading="eager" />
        </figure>
      )}

      {carouselSlides.length > 0 && (
        <section class="article-carousel" aria-label="配图轮播">
          <div class="article-carousel-heading">
            <p class="toc-kicker">Visual Brief</p>
            <h2>一图速览</h2>
            <p class="article-carousel-note">以下配图与公众号、小红书同步发布，可左右切换浏览全文要点。</p>
          </div>
          <div class="article-carousel-shell" data-carousel tabindex="0">
            <button class="carousel-button prev" type="button" data-carousel-prev aria-label="上一张">←</button>
            <figure class="carousel-stage">
              <div class="carousel-viewport" data-carousel-viewport>
                {
                  carouselSlides.map((slide, index) => (
                    <img
                      class:list={["carousel-slide", { active: index === 0 }]}
                      src={slide.src}
                      alt={slide.title}
                      data-carousel-slide
                      data-index={index}
                      loading={index === 0 ? "eager" : "lazy"}
                      decoding="async"
                    />
                  ))
                }
              </div>
              <figcaption class="carousel-caption" data-carousel-caption aria-live="polite">
                <span class="carousel-caption-text">{carouselSlides[0].title}</span>
              </figcaption>
            </figure>
            <button class="carousel-button next" type="button" data-carousel-next aria-label="下一张">→</button>
          </div>
          <div class="carousel-dots" data-carousel-dots>
            {
              carouselSlides.map((slide, index) => (
                <button
                  class:list={["carousel-dot", { active: index === 0 }]}
                  type="button"
                  data-carousel-dot={index}
                  aria-label={`第 ${index + 1} 张：${slide.title}`}
                />
              ))
            }
          </div>
        </section>
      )}

      <aside class="article-toc" aria-label="章节目录">
        <details class="article-toc-inner" open>
          <summary class="toc-panel-summary">
            <span class="toc-kicker">章节目录</span>
          </summary>
          <ol class="toc-list">
            {
              tocSections.map((section) => (
                <li>
                  <a class="toc-link toc-link-section" href={`#${section.id}`}>
                    {section.text}
                  </a>
                  {section.children.length > 0 && (
                    <ol class="toc-children">
                      {section.children.map((child) => (
                        <li>
                          <a class="toc-link toc-link-child" href={`#${child.id}`}>
                            {child.text}
                          </a>
                        </li>
                      ))}
                    </ol>
                  )}
                </li>
              ))
            }
          </ol>
        </details>
      </aside>

      <section class="article-speed-read" aria-labelledby="speed-read-title">
        <div class="speed-read-heading">
          <p class="toc-kicker">AI 速读</p>
          <h2 id="speed-read-title">5 分钟速读</h2>
        </div>
        <ol class="speed-read-list">
          {speedReadPoints.map((point) => <li>{point}</li>)}
        </ol>
      </section>

      <div class="article-content" set:html={article.html} />
    </div>
  </article>

  {
    carouselSlides.length > 0 && (
      <script define:vars={{ carouselTitles: carouselSlides.map((slide) => slide.title) }}>
        const root = document.querySelector("[data-carousel]");
        if (root) {
          const viewport = root.querySelector("[data-carousel-viewport]");
          const slides = Array.from(root.querySelectorAll("[data-carousel-slide]"));
          const dots = Array.from(document.querySelectorAll("[data-carousel-dot]"));
          const caption = root.querySelector(".carousel-caption-text");
          const prev = root.querySelector("[data-carousel-prev]");
          const next = root.querySelector("[data-carousel-next]");
          const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          const duration = reducedMotion ? 0 : 420;
          let index = 0;
          let animating = false;

          const show = (nextIndex, direction = 0) => {
            const normalized = (nextIndex + slides.length) % slides.length;
            if (animating || normalized === index) return;

            const outgoing = slides[index];
            const incoming = slides[normalized];
            animating = true;

            const applyChange = () => {
              if (direction !== 0 && !reducedMotion) {
                outgoing.classList.remove("active");
                outgoing.classList.add(direction > 0 ? "is-exit-left" : "is-exit-right");
                incoming.classList.add("active");
              } else {
                outgoing.classList.remove("active");
                incoming.classList.add("active");
              }
            };

            if (direction !== 0 && !reducedMotion) {
              incoming.classList.add(direction > 0 ? "is-enter-right" : "is-enter-left");
              requestAnimationFrame(() => {
                requestAnimationFrame(applyChange);
              });
            } else {
              applyChange();
            }

            dots.forEach((dot, dotIndex) => dot.classList.toggle("active", dotIndex === normalized));

            if (caption) {
              caption.classList.add("is-changing");
              window.setTimeout(() => {
                caption.textContent = carouselTitles[normalized] ?? "";
                caption.classList.remove("is-changing");
              }, reducedMotion ? 0 : duration / 2);
            }

            index = normalized;

            window.setTimeout(() => {
              outgoing.classList.remove("is-exit-left", "is-exit-right");
              incoming.classList.remove("is-enter-right", "is-enter-left");
              animating = false;
            }, duration);
          };

          prev?.addEventListener("click", () => show(index - 1, -1));
          next?.addEventListener("click", () => show(index + 1, 1));
          dots.forEach((dot) => {
            dot.addEventListener("click", () => {
              const target = Number(dot.getAttribute("data-carousel-dot"));
              show(target, target > index ? 1 : target < index ? -1 : 0);
            });
          });

          root.addEventListener("keydown", (event) => {
            if (event.key === "ArrowLeft") {
              event.preventDefault();
              show(index - 1, -1);
            }
            if (event.key === "ArrowRight") {
              event.preventDefault();
              show(index + 1, 1);
            }
          });

          if (viewport) {
            let touchStartX = 0;
            viewport.addEventListener(
              "touchstart",
              (event) => {
                touchStartX = event.changedTouches[0]?.clientX ?? 0;
              },
              { passive: true },
            );
            viewport.addEventListener(
              "touchend",
              (event) => {
                const delta = (event.changedTouches[0]?.clientX ?? 0) - touchStartX;
                if (Math.abs(delta) < 48) return;
                show(delta < 0 ? index + 1 : index - 1, delta < 0 ? 1 : -1);
              },
              { passive: true },
            );
          }
        }
      </script>
    )
  }
</BaseLayout>
