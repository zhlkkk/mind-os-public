---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getArticleBySlug, getArticles } from "@/lib/content";

export function getStaticPaths() {
  return getArticles().map((article) => ({
    params: { slug: article.frontmatter.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const discussionUrl = article.frontmatter.discussion?.url;
---

<BaseLayout title={`${article.frontmatter.title} · Mind-OS Public`} description={article.frontmatter.summary}>
  <article class="article-page">
    <header class="article-hero">
      <a class="back-link" href="/">← 返回文章列表</a>
      <p class="eyebrow">Article · {article.frontmatter.date} · {article.readingMinutes} 分钟</p>
      <h1>{article.frontmatter.title}</h1>
      <p class="article-summary">{article.frontmatter.summary}</p>
      <div class="article-meta">
        <div class="tags">
          {article.frontmatter.tags.map((tag, index) => <span class={`tag tone-${(index % 5) + 1}`}>{tag}</span>)}
        </div>
        {discussionUrl && <a class="button primary compact" href={discussionUrl}>参与讨论 #{article.frontmatter.discussion?.issue}</a>}
      </div>
    </header>
    <div class="article-content" set:html={article.html} />
  </article>
</BaseLayout>
