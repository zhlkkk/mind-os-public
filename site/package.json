{
  "name": "mind-os-public-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-assets.mjs",
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev --host 127.0.0.1",
    "prebuild": "node scripts/sync-assets.mjs",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview --host 127.0.0.1",
    "verify": "npm run build && node scripts/verify-build.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "astro": "^6.3.6",
    "marked": "^15.0.12"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
